{
  "expo": {
    "name": "Sales Team Tracker",
    "slug": "sales-team-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "salesteamtracker",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.codewilson64.salesteamtracker",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Sales Team Tracker to access your camera to take photos of clients or products.",
        "NSPhotoLibraryUsageDescription": "Allow Sales Team Tracker to access your photo library to select and upload images.",
        "NSPhotoLibraryAddUsageDescription": "Allow Sales Team Tracker to save photos to your library.",
        "NSLocationWhenInUseUsageDescription": "Allow Sales Team Tracker to use your location to track sales visits and improve accuracy."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/logo.png"
      },
      "package": "com.codewilson64.salesteamtracker",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Sales Team Tracker to use your location for better experience."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/logo.png",
          "resizeMode": "contain",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/visit_notification.png",
          "color": "#000000",
          "defaultChannel": "field_activity"
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3eabf7b3-94b6-4dc8-9b05-40abda72f010"
      }
    }
  }
}
